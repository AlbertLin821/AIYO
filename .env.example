# Core database
DATABASE_URL=postgresql://aiyo:aiyo_password@localhost:5432/aiyo_db

# Redis
REDIS_URL=redis://localhost:6379

# Ollama / LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_NUM_PREDICT_CHAT=8192
# OLLAMA_NUM_CTX_CHAT=8192

# Internal service trust
AI_SERVICE_INTERNAL_TOKEN=replace_with_long_random_internal_token
AI_SERVICE_ALLOWED_ORIGINS=http://localhost:3001
AI_SERVICE_ALLOWED_IPS=127.0.0.1,::1

# API keys
YOUTUBE_API_KEY=your_youtube_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# App runtime
NODE_ENV=development
API_PORT=3001
AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# JWT / auth
JWT_SECRET=replace_with_secure_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=aiyo_refresh_token

# Optional observability and behavior flags
ENABLE_GATEWAY_MEMORY_EXTRACT=false
SENTRY_DSN=

# AIYO V2 contracts
V2_EMBED_MODEL_NAME=nomic-embed-text
V2_EMBED_MODEL_VERSION=1
V2_EMBED_DIM=768
V2_RECOMMEND_SYNC_TIMEOUT_SEC=3.5
V2_PLAN_SYNC_TIMEOUT_SEC=5.0
V2_JOB_POLL_AFTER_MS=1200
V2_YOUTUBE_STATS_TTL_HOURS=24
V2_GEOCODE_MAX_RETRIES=3
V2_JOB_POLL_INTERVAL_MS=1200

# Phase-C switch controls
V1_READONLY_MODE=false
V1_READONLY_EXCLUDED_PREFIXES=/api/v2,/api/auth,/api/dev,/health,/metrics
LEGACY_FRONTEND_PATH=/legacy
NEXT_PUBLIC_PHASE_C_READONLY=false
