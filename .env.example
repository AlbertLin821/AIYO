# AIYO 愛遊 - 環境變數範本
# 請複製此檔案為 .env 並填入實際值
# 指令: copy .env.example .env

# ========== 資料庫 ==========
DATABASE_URL=postgresql://aiyo:aiyo_password@localhost:5432/aiyo_db

# ========== Redis ==========
REDIS_URL=redis://localhost:6379

# ========== Ollama / LLM ==========
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ========== 內部服務安全 ==========
# gateway 與 ai-service 必須使用相同 token
AI_SERVICE_INTERNAL_TOKEN=replace_with_long_random_internal_token
# 僅允許 gateway 的來源（ai-service CORS）
AI_SERVICE_ALLOWED_ORIGINS=http://localhost:3001
# 僅允許內部呼叫 IP（ai-service 白名單）
AI_SERVICE_ALLOWED_IPS=127.0.0.1,::1

# ========== YouTube API ==========
# 取得方式請參考 docs/API金鑰取得與配置指南.md
YOUTUBE_API_KEY=your_youtube_api_key_here

# ========== Google Maps API ==========
# 需啟用: Places API, Directions API, Distance Matrix API
# 取得方式請參考 docs/API金鑰取得與配置指南.md
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# ========== Whisper（語音轉文字）==========
# 選項 1: 使用 OpenAI Whisper API（需付費）
OPENAI_API_KEY=your_openai_api_key_here

# 選項 2: 使用本地 Whisper（不需此變數）
# 本專案預設使用本地 Whisper，可省略 OPENAI_API_KEY

# ========== 應用程式設定 ==========
NODE_ENV=development
API_PORT=3001
AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
JWT_SECRET=replace_with_secure_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=aiyo_refresh_token

# 是否保留 gateway 端長期記憶抽取（建議 false，改由 ai-service 主責）
ENABLE_GATEWAY_MEMORY_EXTRACT=false

# 監控（可留空）
SENTRY_DSN=